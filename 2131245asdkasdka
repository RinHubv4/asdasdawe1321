local function createRinToggle(titleText, desc, yPos)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(0.95, 0, 0, 120)
    card.Position = UDim2.new(0.025, 0, 0, yPos)
    card.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    card.BorderSizePixel = 0
    card.Parent = main
    
    local cardCorner = Instance.new("UICorner")
    cardCorner.CornerRadius = UDim.new(0, 12)
    cardCorner.Parent = card
    
    -- Progress bar
    local progressBar = Instance.new("Frame")
    progressBar.Size = UDim2.new(0, 0, 0, 4)
    progressBar.Position = UDim2.new(0, 0, 1, -4)
    progressBar.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
    progressBar.BorderSizePixel = 0
    progressBar.Parent = card
    
    local progressCorner = Instance.new("UICorner")
    progressCorner.CornerRadius = UDim.new(0, 2)
    progressCorner.Parent = progressBar
    
    -- Hover effect
    card.MouseEnter:Connect(function()
        TweenService:Create(card, TweenInfo.new(0.3), {
            BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        }):Play()
    end)
    
    card.MouseLeave:Connect(function()
        TweenService:Create(card, TweenInfo.new(0.3), {
            BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        }):Play()
    end)
    
    -- Icon
    local toggleIcon = Instance.new("TextLabel")
    toggleIcon.Size = UDim2.new(0, 35, 0, 35)
    toggleIcon.Position = UDim2.new(0, 15, 0, 15)
    toggleIcon.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    toggleIcon.BackgroundTransparency = 0.5
    toggleIcon.Text = titleText == "Freeze Trade" and "❄️" or titleText == "Auto Ready" and "✓" or "🔄"
    toggleIcon.TextColor3 = Color3.fromRGB(200, 200, 200)
    toggleIcon.TextSize = 20
    toggleIcon.Font = Enum.Font.Gotham
    toggleIcon.BorderSizePixel = 0
    toggleIcon.Parent = card
    
    local iconCorner = Instance.new("UICorner")
    iconCorner.CornerRadius = UDim.new(0, 10)
    iconCorner.Parent = toggleIcon

    -- Title
    local cardTitle = Instance.new("TextLabel")
    cardTitle.Size = UDim2.new(0.5, 0, 0, 30)
    cardTitle.Position = UDim2.new(0, 60, 0, 15)
    cardTitle.BackgroundTransparency = 1
    cardTitle.Text = titleText
    cardTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
    cardTitle.TextSize = 18
    cardTitle.TextXAlignment = Enum.TextXAlignment.Left
    cardTitle.Font = Enum.Font.GothamBold
    cardTitle.Parent = card
    
    -- Description
    local cardDesc = Instance.new("TextLabel")
    cardDesc.Size = UDim2.new(0.6, 0, 0, 25)
    cardDesc.Position = UDim2.new(0, 60, 0, 45)
    cardDesc.BackgroundTransparency = 1
    cardDesc.Text = desc
    cardDesc.TextColor3 = Color3.fromRGB(140, 140, 140)
    cardDesc.TextSize = 13
    cardDesc.TextXAlignment = Enum.TextXAlignment.Left
    cardDesc.Font = Enum.Font.Gotham
    cardDesc.Parent = card
    
    -- Status dot
    local statusDot = Instance.new("Frame")
    statusDot.Size = UDim2.new(0, 12, 0, 12)
    statusDot.Position = UDim2.new(1, -190, 0, 22)
    statusDot.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    statusDot.BorderSizePixel = 0
    statusDot.Parent = card
    
    local dotCorner = Instance.new("UICorner")
    dotCorner.CornerRadius = UDim.new(1, 0)
    dotCorner.Parent = statusDot
    
    -- Status text
    local statusText = Instance.new("TextLabel")
    statusText.Size = UDim2.new(0, 100, 0, 25)
    statusText.Position = UDim2.new(1, -175, 0, 16)
    statusText.BackgroundTransparency = 1
    statusText.Text = "Inactive"
    statusText.TextColor3 = Color3.fromRGB(200, 0, 0)
    statusText.TextSize = 14
    statusText.Font = Enum.Font.GothamMedium
    statusText.TextXAlignment = Enum.TextXAlignment.Left
    statusText.Parent = card
    
    -- ON/OFF Button
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(0, 80, 0, 35)
    toggleBtn.Position = UDim2.new(1, -100, 0, 65)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    toggleBtn.BackgroundTransparency = 0.2
    toggleBtn.Text = "OFF"
    toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggleBtn.TextSize = 15
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.BorderSizePixel = 0
    toggleBtn.Parent = card
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = toggleBtn
    
    -- Toggle functionality
    local active = false
    local isProcessing = false
    
    local function setState(newState)
        active = newState
        
        if active then
            toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
            toggleBtn.Text = "ON"
            statusDot.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
            statusText.Text = "Active"
            statusText.TextColor3 = Color3.fromRGB(0, 200, 0)
        else
            toggleBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
            toggleBtn.Text = "OFF"
            statusDot.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
            statusText.Text = "Inactive"
            statusText.TextColor3 = Color3.fromRGB(200, 0, 0)
        end
    end
    
    toggleBtn.MouseButton1Click:Connect(function()
        if isProcessing then return end
        
        if not active then
            isProcessing = true
            
            toggleBtn.BackgroundColor3 = Color3.fromRGB(255, 140, 0)
            toggleBtn.Text = "..."
            statusDot.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
            statusText.Text = "Activating"
            statusText.TextColor3 = Color3.fromRGB(255, 170, 0)
            
            TweenService:Create(progressBar, TweenInfo.new(3), {
                Size = UDim2.new(1, 0, 0, 4)
            }):Play()
            
            local pulse = 0
            local pulseConnection
            pulseConnection = RunService.Heartbeat:Connect(function(dt)
                pulse = (pulse + dt * 3) % 1
                local transparency = 0.2 + math.sin(pulse * math.pi) * 0.4
                statusDot.BackgroundTransparency = transparency
            end)
            
            task.wait(3.5)
            
            if pulseConnection then
                pulseConnection:Disconnect()
            end
            statusDot.BackgroundTransparency = 0
            
            setState(true)
            
            task.wait(0.3)
            progressBar.Size = UDim2.new(0, 0, 0, 4)
            
            isProcessing = false
            
        else
            setState(false)
            progressBar.Size = UDim2.new(0, 0, 0, 4)
        end
    end)
    
    return card
end

